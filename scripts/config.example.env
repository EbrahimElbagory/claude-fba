# claude-fba configuration — copy to scripts/config.env and fill in.
# config.env is gitignored. NEVER commit real values.
# Get these from your self-authorized SP-API app (see docs/SETUP.md).

# --- Amazon SP-API (required) ---
# LWA credentials from Seller Central -> Apps & Services -> Develop Apps
LWA_CLIENT_ID=amzn1.application-oa2-client.EXAMPLE0000000000000000000000000
LWA_CLIENT_SECRET=amzn1.oa2-cs.v1.EXAMPLE00000000000000000000000000000000
SP_REFRESH_TOKEN=Atzr|EXAMPLE...

# Region: na | eu | fe  (run `python3 sp_api.py` to auto-detect yours)
SP_REGION=na

# Marketplace to operate in (default US). Common ids:
# US=ATVPDKIKX0DER  CA=A2EUQ1WTGCTBG2  UK=A1F83G8C2ARO7P  DE=A1PA6795UKMFR9
MARKETPLACE_ID=ATVPDKIKX0DER

# --- Amazon Ads API (optional; only for PPC automation, see scripts/ads_api.py) ---
# ADS_CLIENT_ID=amzn1.application-oa2-client.EXAMPLE
# ADS_CLIENT_SECRET=EXAMPLE
# ADS_REFRESH_TOKEN=Atzr|EXAMPLE
# ADS_PROFILE_ID=1234567890
